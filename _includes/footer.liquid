{% if site.footer_fixed %}
  <footer class="fixed-bottom" role="contentinfo">
    <div class="container footer-inner">
      <a class="footer-brand" href="{{ '/' | relative_url }}">
        <img src="{{ '/assets/img/logo2.png' | relative_url }}" alt="PIER Lab" class="footer-logo-img" onerror="this.style.display='none'">
        <span class="footer-logo-text">PIER LAB<span class="footer-logo-sub">KIST</span></span>
      </a>
      <div class="footer-copy">
        &copy; {{ site.time | date: '%Y' }} Physical Intelligence &amp; Embodied Robotics Laboratory, KIST.
      </div>
    </div>
  </footer>
{% else %}
  <footer class="sticky-bottom mt-5" role="contentinfo">
    {% if site.newsletter.enabled %}
      {% include newsletter.liquid %}
    {% endif %}

    <div class="container footer-inner">
      <a class="footer-brand" href="{{ '/' | relative_url }}">
        <img src="{{ '/assets/img/logo2.png' | relative_url }}" alt="PIER Lab" class="footer-logo-img" onerror="this.style.display='none'">
        <span class="footer-logo-text">PIER LAB<span class="footer-logo-sub">KIST</span></span>
      </a>
      <div class="footer-copy">
        &copy; {{ site.time | date: '%Y' }} Physical Intelligence &amp; Embodied Robotics Laboratory, KIST.
      </div>
    </div>
  </footer>
{% endif %}
