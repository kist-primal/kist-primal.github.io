@article{kim2025manipulation,
  title     = {Tactile-Guided Dexterous Manipulation in Cluttered Environments},
  author    = {Kim, Minjun and Park, Soyeon and Lee, Hyunwoo},
  journal   = {IEEE Robotics and Automation Letters (RA-L)},
  year      = {2025},
  abbr      = {RA-L},
  selected  = {true},
  bibtex_show = {true},
  pdf       = {kim2025manipulation.pdf},
  abstract  = {We present a tactile-guided manipulation framework that combines dense tactile feedback with model-based grasp planning, enabling robust handling of objects with unknown geometry in cluttered scenes.}
}

@inproceedings{park2025embodied,
  title     = {Language-Conditioned Manipulation via Physical Interaction Learning},
  author    = {Park, Soyeon and Choi, Minji},
  booktitle = {IEEE International Conference on Robotics and Automation (ICRA)},
  year      = {2025},
  abbr      = {ICRA},
  selected  = {true},
  bibtex_show = {true},
  pdf       = {park2025embodied.pdf},
  code      = {https://github.com/pier-lab/lang-manip},
  abstract  = {We propose a language-conditioned policy learning framework where a robot acquires manipulation skills from human demonstrations annotated with natural language instructions, enabling zero-shot generalization to novel task descriptions.}
}

@inproceedings{lee2024perception,
  title     = {Real-time Multi-modal 3D Perception for Contact-Rich Manipulation},
  author    = {Lee, Hyunwoo and Kim, Minjun and Seo, Yujin},
  booktitle = {IEEE/RSJ International Conference on Intelligent Robots and Systems (IROS)},
  year      = {2024},
  abbr      = {IROS},
  selected  = {true},
  bibtex_show = {true},
  pdf       = {lee2024perception.pdf},
  abstract  = {We introduce a lightweight multi-modal perception architecture that fuses LiDAR, RGB-D, and tactile data for real-time 3D state estimation during contact-rich robot manipulation tasks.}
}

@article{choi2024simtoreal,
  title     = {Sim-to-Real Transfer for Deformable Object Manipulation},
  author    = {Choi, Minji and Park, Soyeon},
  journal   = {IEEE Transactions on Robotics (T-RO)},
  year      = {2024},
  abbr      = {T-RO},
  bibtex_show = {true},
  pdf       = {choi2024simtoreal.pdf},
  abstract  = {We propose a domain randomization and adaptation framework for transferring manipulation policies trained in simulation to real robotic systems with minimal fine-tuning on physical deformable objects.}
}
